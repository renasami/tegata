{
  "name": "tegata",
  "version": "0.1.0",
  "description": "Enforceable authorization for MCP tool calls",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "packageManager": "pnpm@10.11.0",
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "prettier": "^3.5.3",
    "@types/node": "^22.14.1"
  }
}
